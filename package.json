{
  "name": "taro",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @taro/web --filter @taro/realtime dev",
    "dev:web": "pnpm --filter @taro/web dev",
    "dev:realtime": "pnpm --filter @taro/realtime dev",
    "build": "pnpm prisma:generate && pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm lint && pnpm test && pnpm build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema packages/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema packages/database/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx packages/database/src/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "esbuild", "sharp", "unrs-resolver"]
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
